LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
LLM_MODEL=your_model_name
LLM_TIMEOUT_SECONDS=60
# Optional chatbot webhook security. Set same token in Telegram/Zalo webhook URL or header.
LAUNCHOPS_WEBHOOK_TOKEN=change_me

# Optional Telegram delivery. Webhook still returns reply JSON when unset.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional Zalo Bot delivery. Same as Telegram but for Zalo OpenAPI.
ZALO_BOT_TOKEN=your_zalo_bot_token_here

# Optional: 1 keeps chatbot replies fast/deterministic; 0 uses full LLM orchestration.
CHATBOT_FAST_MODE=1

# Optional: 1 turns on caveman style responses by default for the chatbot.
LAUNCHOPS_CAVEMAN_STYLE=0

# Optional AgentBase Memory. Leave disabled unless a Memory Store + strategy exist.
LAUNCHOPS_MEMORY_ENABLED=false
LAUNCHOPS_MEMORY_ID=
LAUNCHOPS_MEMORY_STRATEGY_ID=
LAUNCHOPS_MEMORY_NAMESPACE_MODE=actor
LAUNCHOPS_MEMORY_DEMO_FALLBACK_ENABLED=false
LAUNCHOPS_MEMORY_TIMEOUT_SECONDS=8

# WS5 6-LLM-agents: memory agent LLM-distills recalled knowledge, orchestrator agent LLM-writes an
# executive go/no-go synthesis. Both default on; skipped on MCP fast path. Optional per-agent models.
LAUNCHOPS_MEMORY_LLM_ENABLED=true
LAUNCHOPS_ORCHESTRATOR_LLM_ENABLED=true
# LAUNCHOPS_MODEL_MEMORY=
# LAUNCHOPS_MODEL_ORCHESTRATOR=

# WS1 RAG knowledge grounding. Recall curated playbooks from a SEPARATE knowledge memory store and
# inject top-k into each agent prompt. Default off; turn on after seeding the store (server/seed_knowledge.py).
LAUNCHOPS_RAG_ENABLED=false
LAUNCHOPS_KNOWLEDGE_MEMORY_ID=

# WS3 content guardrail: reject analyze when brief has hard secrets (private key, card/cvv/otp, password),
# mask soft PII (email/phone) then proceed. Default on; only rejects on hard secrets so demo briefs pass.
LAUNCHOPS_GUARDRAIL_ENABLED=true

# WS4 app-level rate limit for the expensive LLM analyze path (sliding window, in-memory, per client IP).
# Default off for demo. MCP fast path is exempt. In-memory: resets on restart, not shared across replicas.
LAUNCHOPS_RATELIMIT_ENABLED=false
LAUNCHOPS_RATELIMIT_ANALYZE_PER_MIN=10
LAUNCHOPS_RATELIMIT_ANALYZE_PER_DAY=200

# Optional business storage. Keep local unless a VNG vDB/Postgres instance exists.
LAUNCHOPS_STORAGE_BACKEND=local
# Use the RW endpoint from VNG vDB Connectivity & Security -> Endpoint & Port.
# Example only: postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
LAUNCHOPS_DB_URL=
LAUNCHOPS_DB_TIMEOUT_SECONDS=5

# Optional Phase 4 independent runtime role. Keep orchestrator for the main web/API/MCP runtime.
# Other accepted values: readiness, redteam, checklist, postmortem, memory.
LAUNCHOPS_AGENT_ROLE=orchestrator
LAUNCHOPS_AGENT_FORCE_FAST=false
LAUNCHOPS_USE_REMOTE_AGENTS=false
LAUNCHOPS_AGENT_TIMEOUT_SECONDS=75
# Optional shared bearer token for orchestrator -> child runtime calls if those endpoints require it.
LAUNCHOPS_AGENT_INVOCATION_TOKEN=

# Optional Phase 4 child runtime endpoints for the orchestrator, filled only after separate runtimes exist.
LAUNCHOPS_READINESS_URL=
LAUNCHOPS_REDTEAM_URL=
LAUNCHOPS_CHECKLIST_URL=
LAUNCHOPS_POSTMORTEM_URL=
LAUNCHOPS_MEMORY_URL=
